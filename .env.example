# ══════════════════════════════════════════════════════
#  Private CRM — Altum Wealth  |  .env.example
#  Copie para .env e preencha antes de rodar
# ══════════════════════════════════════════════════════

# ── Anthropic (Claude / Sofia) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Z-API (WhatsApp) ───────────────────────────────────
# Painel: https://app.z-api.io
ZAPI_INSTANCE_ID=seu_instance_id
ZAPI_TOKEN=seu_token
ZAPI_CLIENT_TOKEN=seu_client_token

# ── Hariton (alertas + relatório diário) ───────────────
# Formato: DDI + DDD + número, sem espaços (ex: 5511999999999)
HARITON_WHATSAPP=5511999999999

# ── Banco de dados ─────────────────────────────────────
# DESENVOLVIMENTO LOCAL (SQLite):
#   DATABASE_URL="file:./dev.db"
#   Obs: mude o schema.prisma para provider = "sqlite"
#
# PRODUÇÃO (Neon PostgreSQL — gratuito):
#   1. Crie conta em https://neon.tech
#   2. Crie um projeto > copie a "Connection string"
#   3. Cole abaixo:
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Cron (segurança dos endpoints GitHub Actions) ──────
# Qualquer string segura — use um gerador de senhas
CRON_SECRET=altum-cron-super-secreto-2024

# ── Agendamentos ───────────────────────────────────────
MAX_REUNIOES_DIA=2
TZ=America/Sao_Paulo

# ── Servidor ───────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
